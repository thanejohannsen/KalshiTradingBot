# ============================================================
# Kalshi Prediction Market Bot — Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All secrets are loaded from .env — never commit that file.
# ============================================================

# --- Execution Mode ---
# "paper" = simulate trades only (no real orders)
# "live"  = place real orders on Kalshi
MODE=live

# --- Kalshi API ---
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2

# --- Anthropic / Claude (optional — leave blank to disable) ---
ANTHROPIC_API_KEY=

# --- Reddit (register free app at https://www.reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=KalshiBot/1.0

# --- NewsAPI (free key at https://newsapi.org/register) ---
NEWSAPI_KEY=

# --- Scan Agent Thresholds ---
SCAN_INTERVAL_SECONDS=300
MIN_VOLUME_24H=50
MIN_LIQUIDITY_DOLLARS=500
MAX_TIME_TO_RESOLUTION_DAYS=30
MIN_TIME_TO_RESOLUTION_HOURS=1
PRICE_MOVE_THRESHOLD_PCT=10
VOLUME_SPIKE_MULTIPLIER=3.0
WIDE_SPREAD_CENTS=5

# --- Prediction Agent ---
MIN_EDGE_THRESHOLD=0.05

# --- Risk Agent ---
BANKROLL=50.0
MAX_EXPOSURE_PCT=0.05
KELLY_FRACTION=0.25

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=kalshi_bot.log
